<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="apply_inherit_mod_recruitment" model="ir.ui.view">
        <field name="name">hr.applicant.website.form.inherit.mod_recruitment</field>
        <field name="inherit_id" ref="website_hr_recruitment.apply"/>
        <field name="arch" type="xml">
            
            <xpath expr="//input[@name='Resume']/../../.." position="after">
                
                <div class="col-12 mb-0 py-2 s_website_form_field s_website_form_required s_website_form_model_required" data-type="float" data-name="Field">
                    <div class="row s_col_no_resize s_col_no_bgcolor">
                        <label class="col-4 col-sm-auto s_website_form_label" style="width: 200px" for="recruitment_type_id">
                            <span class="s_website_form_label_content">Título académico</span>
                        </label>
                        <div class="col-sm">
                            <select id="recruitment_type_id" class="form-select s_website_form_input" name="type_id" required="1">
                                <option value="">Selecciona una opción...</option>
                                <t t-foreach="request.env['hr.recruitment.degree'].sudo().search([])" t-as="type">
                                    <option t-att-value="type.id"><t t-esc="type.name"/></option>
                                </t>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="col-12 mb-0 py-2 s_website_form_field s_website_form_required s_website_form_model_required" data-type="float" data-name="Field">
                    <div class="row s_col_no_resize s_col_no_bgcolor">
                        <label class="col-4 col-sm-auto s_website_form_label" style="width: 200px" for="recruitment_salary">
                            <span class="s_website_form_label_content">Salario Esperado (USD)</span>
                        </label>
                        <div class="col-sm">
                            <input id="recruitment_salary" 
                                type="number" 
                                step="0.01" 
                                min="0" 
                                class="form-control s_website_form_input" 
                                name="salary_expected" 
                                placeholder="Ej. 1500.00" 
                                required="1"/>
                        </div>
                    </div>
                </div>

                <div class="col-12 mb-0 py-2 s_website_form_field s_website_form_required s_website_form_model_required" data-type="date" data-name="Field">
                    <div class="row s_col_no_resize s_col_no_bgcolor">
                        <label class="col-4 col-sm-auto s_website_form_label" style="width: 200px" for="recruitment_availability">
                            <span class="s_website_form_label_content">¿Cuándo podrías empezar a trabajar?</span>
                        </label>
                        <div class="col-sm">
                            <input id="recruitment_availability" 
                                type="date" 
                                class="form-control s_website_form_input" 
                                name="availability" 
                                required="1"/>
                        </div>
                    </div>
                </div>

                <div class="col-12 mb-0 py-2 s_website_form_field s_website_form_required s_website_form_model_required" data-type="many2one" data-name="Field">
                    <div class="row s_col_no_resize s_col_no_bgcolor">
                        <label class="col-4 col-sm-auto s_website_form_label" style="width: 200px" for="recruitment_medium">
                            <span class="s_website_form_label_content">¿Por qué medio nos encontraste?</span>
                        </label>
                        <div class="col-sm">
                            <select id="recruitment_medium" class="form-select s_website_form_input" name="medium_id" required="">
                                <option value="">Selecciona una opción...</option>
                                <t t-foreach="request.env['utm.medium'].sudo().search([])" t-as="medium">
                                    <option t-att-value="medium.id"><t t-esc="medium.name"/></option>
                                </t>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="col-12 mb-0 py-2 s_website_form_field s_website_form_required s_website_form_model_required" data-type="many2one" data-name="Field">
                    <div class="row s_col_no_resize s_col_no_bgcolor">
                        <label class="col-4 col-sm-auto s_website_form_label" style="width: 200px" for="recruitment_source">
                            <span class="s_website_form_label_content">¿Cuál fue el origen específico?</span>
                        </label>
                        <div class="col-sm">
                            <select id="recruitment_source" class="form-select s_website_form_input" name="source_id" required="">
                                <option value="">Selecciona una opción...</option>
                                <t t-foreach="request.env['utm.source'].sudo().search([])" t-as="source">
                                    <option t-att-value="source.id"><t t-esc="source.name"/></option>
                                </t>
                            </select>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>